NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Server-side only — never expose to client
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Phase 3 — PayMongo Payments (currently unwired from live flow — see HANDOFF.md)
PAYMONGO_SECRET_KEY=       # From PayMongo Dashboard → Developers → API Keys (secret key, sk_live_ or sk_test_)
PAYMONGO_WEBHOOK_SECRET=   # From PayMongo Dashboard → Developers → Webhooks → signing secret
NEXT_PUBLIC_URL=           # Full base URL of your deployment (e.g. https://yourdomain.com or http://localhost:3000)

# Phase 2a — Telegram admin alerts (no-op if unset)
TELEGRAM_BOT_TOKEN=        # From @BotFather
TELEGRAM_CHAT_ID=          # Chat/group id to receive alerts
